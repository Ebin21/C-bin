<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
     android:orientation="vertical"
    android:gravity="center"
    android:background="#d33b33"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    tools:context=".CustHome" >

    
        <Button
         android:id="@+id/buttonprofile"
         android:layout_width="271dp"
         android:layout_height="40dp"
         android:layout_marginTop="30dp"
         android:background="#ffffff"
         android:text="My profile"
         android:textColor="#d33b33"
         android:textStyle="bold" />
       
    
       <Button
         android:id="@+id/buttonnearcargo"
         android:layout_width="271dp"
         android:layout_height="40dp"
         android:layout_marginTop="30dp"
         android:background="#ffffff"
         android:text="View nearby cargo services"
         android:textColor="#d33b33"
         android:textStyle="bold" />
       
       	     <Button
         android:id="@+id/buttonbookings"
         android:layout_width="271dp"
         android:layout_height="40dp"
         android:layout_marginTop="30dp"
         android:background="#ffffff"
         android:text="Cargo bookings"
         android:textColor="#d33b33"
         android:textStyle="bold" />
       	     
       	       <Button
         android:id="@+id/buttonfeedback"
         android:layout_width="271dp"
         android:layout_height="40dp"
         android:layout_marginTop="30dp"
         android:background="#ffffff"
         android:text="Give Feedback"
         android:textColor="#d33b33"
         android:textStyle="bold" />
       	       
       	          
       	       <Button
         android:id="@+id/buttonrate"
         android:layout_width="271dp"
         android:layout_height="40dp"
         android:layout_marginTop="30dp"
         android:background="#ffffff"
         android:text="Review and rate"
         android:textColor="#d33b33"
         android:textStyle="bold" />
       	      
       	       
       	      <Button
         android:id="@+id/buttonlogout"
         android:layout_width="271dp"
         android:layout_height="40dp"
         android:layout_marginTop="30dp"
         android:background="#ffffff"
         android:text="Logout"
         android:textColor="#d33b33"
         android:textStyle="bold" />


</LinearLayout>
